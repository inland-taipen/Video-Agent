# Copy this file to .env and fill in your values

# LLM keys (backend proxy)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Image generation
GEMINI_IMAGE_KEY=your_gemini_image_key_here   # optional, falls back to GEMINI_API_KEY
POLLINATIONS_API_KEY=                          # optional
HF_TOKEN=                                      # optional (HuggingFace)

# TTS settings (ElevenLabs premium voice — highly recommended)
# Get a free API key at https://elevenlabs.io (10,000 chars/mo free)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Rachel (warm narrator)

# Legacy TTS settings (if using edge-tts fallback)
TTS_VOICE=en-US-JennyNeural
TTS_RATE=-8%
TTS_PITCH=+0Hz

# Frontend build-time vars (injected by Docker build args / Render)
VITE_BACKEND_URL=http://localhost:8000

# Groq model override (optional)
GROQ_MODEL=llama-3.3-70b-versatile
